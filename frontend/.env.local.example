# Copy this to `.env.local` (gitignored). Restart `pnpm dev` after changes.
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# Phase 3: point the frontend at the running classifier-service.
NEXT_PUBLIC_CLASSIFIER_URL=http://localhost:8001

# Set to "true" to bypass the network and use the keyword-based mock
# classifier (handy for offline development without the backend).
# NEXT_PUBLIC_USE_MOCK=false

# Phase 8: point the frontend at the running rca-agent-system service
# (Google ADK app). Used by the Agent Explorer page and the agent
# health pill. Same default is hardcoded in src/lib/api/agents.ts so
# leaving this commented out is safe in dev.
NEXT_PUBLIC_AGENT_URL=http://localhost:8000
