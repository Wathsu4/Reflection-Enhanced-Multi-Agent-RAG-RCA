GOOGLE_API_KEY=your-gemini-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=FALSE
ADK_PORT=8000
ADK_CORS_ORIGINS=http://localhost:3000
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=incident_memory
SESSION_DB_URL=sqlite+aiosqlite:///./data/sessions.db
GEMINI_MODEL=gemini-2.5-flash

# Phase 9: enables `POST /demo/reset-memory` which wipes ChromaDB and
# reseeds it from `seed/incidents/`. Destructive. Set to "1" only on
# demo machines; leave unset (default-deny) elsewhere.
ALLOW_DEMO_RESET=0
